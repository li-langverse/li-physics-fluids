import std.physics.fluids

@gpu
def physics_gpu_fluids_heat_smoke() -> int
  requires true
  ensures result >= 0
  ensures result <= 1
  decreases 0
=
  if physics_fluids_std_tag() != 1:
    return 0
  return 1

def main() -> int
  requires true
  ensures result == 0
  decreases 0
=
  if physics_gpu_fluids_heat_smoke() != 1:
    return 1
  return 0
